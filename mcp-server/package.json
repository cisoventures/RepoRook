{
  "name": "@reporook/mcp-server",
  "version": "0.2.0",
  "description": "Read-only MCP tools for RepoRook security scanning and fix verification.",
  "license": "MIT",
  "homepage": "https://github.com/cisoventures/RepoRook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cisoventures/RepoRook.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/cisoventures/RepoRook/issues"
  },
  "type": "module",
  "bin": {
    "reporook-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/index.js',0o755)\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "reporook": "0.2.0"
  }
}
