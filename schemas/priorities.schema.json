{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reporook.dev/schemas/priorities-1.0.json",
  "title": "RepoRook Finding Priorities",
  "type": "object",
  "required": ["schema_version", "tool", "generated_at", "coverage_status", "source_scan", "summary", "priorities"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": { "name": { "const": "reporook" }, "version": { "type": "string" } },
      "additionalProperties": false
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "coverage_status": { "enum": ["complete", "partial", "failed"] },
    "source_scan": { "$ref": "https://reporook.dev/schemas/findings-1.0.json#/$defs/receipt" },
    "summary": {
      "type": "object",
      "required": ["fix_now", "fix_next", "review_later", "total"],
      "properties": {
        "fix_now": { "type": "integer", "minimum": 0 },
        "fix_next": { "type": "integer", "minimum": 0 },
        "review_later": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "priorities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rank", "priority", "finding_id", "severity", "scanner", "package", "file", "line", "title", "reason", "next_step", "related_finding_ids"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "priority": { "enum": ["fix-now", "fix-next", "review-later"] },
          "finding_id": { "type": "string", "pattern": "^rr-[a-f0-9]{12}$" },
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "scanner": { "type": "string" },
          "package": { "type": ["string", "null"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "next_step": { "type": "string", "minLength": 1 },
          "related_finding_ids": { "type": "array", "items": { "type": "string", "pattern": "^rr-[a-f0-9]{12}$" }, "uniqueItems": true }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
