{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reporook.dev/schemas/findings-1.0.json",
  "title": "RepoRook Findings",
  "type": "object",
  "required": ["schema_version", "tool", "target", "generated_at", "coverage_status", "summary", "scanners", "findings", "scan_receipt"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": { "name": { "const": "reporook" }, "version": { "type": "string" } },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["path", "commit"],
      "properties": { "path": { "type": "string" }, "commit": { "type": ["string", "null"] } },
      "additionalProperties": false
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "coverage_status": { "enum": ["complete", "partial", "failed"] },
    "summary": {
      "type": "object",
      "required": ["critical", "high", "medium", "low", "total"],
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "scanners": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "applicable", "available", "version", "status", "finding_count", "duration_ms"],
        "properties": {
          "name": { "type": "string" },
          "applicable": { "type": "boolean" },
          "available": { "type": "boolean" },
          "version": { "type": ["string", "null"] },
          "status": { "enum": ["ok", "skipped", "error"] },
          "finding_count": { "type": "integer", "minimum": 0 },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "scan_receipt": { "$ref": "#/$defs/receipt" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id", "scanner", "rule", "severity", "file", "line", "plain_summary", "description", "remediation_hint", "fingerprint", "references", "metadata"],
      "properties": {
        "id": { "type": "string", "pattern": "^rr-[a-f0-9]{12}$" },
        "scanner": { "type": "string" },
        "rule": { "type": "string" },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 },
        "plain_summary": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "remediation_hint": { "type": "string" },
        "fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "references": { "type": "array", "items": { "type": "string" } },
        "metadata": {
          "type": "object",
          "required": ["cwe", "cve", "package", "raw_severity"],
          "properties": {
            "cwe": { "type": "array", "items": { "type": "string" } },
            "cve": { "type": "array", "items": { "type": "string" } },
            "package": { "type": ["string", "null"] },
            "installed_version": { "type": ["string", "null"] },
            "fixed_versions": { "type": "array", "items": { "type": "string" } },
            "raw_severity": { "type": ["string", "null"] },
            "confidence": { "type": ["string", "null"] },
            "tags": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "receipt": {
      "type": "object",
      "required": ["target", "commit", "config_hash", "scanner_versions", "started_at", "completed_at"],
      "properties": {
        "target": { "type": "string" },
        "commit": { "type": ["string", "null"] },
        "config_hash": { "type": "string" },
        "scanner_versions": { "type": "object", "additionalProperties": { "type": ["string", "null"] } },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "changed_files": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
